{
    "version": 2,
    "builds": [
        {
            "src": "portfolio_project/wsgi.py",
            "use": "@vercel/python"
        }
    ],
    "routes": [
        {
            "src": "/(.*)",
            "dest": "portfolio_project/wsgi.py"
        }
    ],
    "env": {
        "DJANGO_SETTINGS_MODULE": "portfolio_project.settings",
        "PIP_BREAK_SYSTEM_PACKAGES": "1"
    }
}
