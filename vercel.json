{
    "version": 2,
    "builds": [
        {
            "src": "vercel/handler.py",
            "use": "@vercel/python"
        }
    ],
    "routes": [
        {
            "src": "/static/(.*)",
            "dest": "staticfiles/$1"
        },
        {
            "src": "/(.*)",
            "dest": "vercel/handler.py"
        }
    ],
    "env": {
        "DJANGO_SETTINGS_MODULE": "portfolio_project.settings"
    }
}
